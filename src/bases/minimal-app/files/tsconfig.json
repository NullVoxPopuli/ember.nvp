{
  "extends": "@ember/app-tsconfig",
  "compilerOptions": {
    "allowJs": true,
    // @ember/app-tsconfig's target (es2024) predates APIs node 24 and
    // evergreen browsers ship (e.g. RegExp.escape)
    "lib": ["esnext", "dom", "dom.iterable"],
    "types": [
      "ember-source/types",
      "@embroider/core/virtual",
      "vite/client",
      "@glint/ember-tsc/types"
    ]
  }
}
